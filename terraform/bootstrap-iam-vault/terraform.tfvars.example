aws_region = "us-east-1"

vault_aws_user_name = "vault-aws-user"
terraform_role_name = "terraform-workload-role"
workload_iam_name   = "aws-ec2"

# Append extra statements to the generated default policy.
additional_terraform_policy_statements = []

# Set true only when you intentionally want Terraform to create and store
# a long-lived access key for Vault root config.
create_vault_access_key = true

tags = {
  project     = "iac-demo"
  managed_by  = "terraform"
  environment = "prod"
}
